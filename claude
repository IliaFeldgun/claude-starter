#!/usr/bin/env bash
set -euo pipefail
COMPOSE_DIR=~/work/claude-starter
COMPOSE_PROJECT_NAME=claude
export CLAUDE_WORKSPACE="$PWD"

update=0
args=()
for arg in "$@"; do
  if [[ "$arg" == "--update" ]]; then
    update=1
  else
    args+=("$arg")
  fi
done

compose=(docker compose -p $COMPOSE_PROJECT_NAME -f "$COMPOSE_DIR/docker-compose.yaml")

if [[ $update -eq 1 ]]; then
  "${compose[@]}" build --pull --no-cache claude
fi

exec "${compose[@]}" run --build --rm claude ${args[@]:-}
